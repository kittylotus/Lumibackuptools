#!/usr/bin/env bash
set -euo pipefail
shopt -s nullglob

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck disable=SC1091
. "$SCRIPT_DIR/lumitools-common"

if [ ! -d "$LUMI_DIR" ]; then
  echo "Lumiverse folder not found at: $LUMI_DIR" >&2
  exit 1
fi

resolve_backup_file() {
  local input="${1:-}"

  if [ -z "$input" ]; then
    return 1
  fi

  if [ "$input" = "latest" ]; then
    local latest
    latest=$(ls -t "$BACKUP_DIR"/lumi_backup_*.tar.gz 2>/dev/null | head -n 1 || true)
    if [ -z "$latest" ]; then
      echo "No backup files found." >&2
      exit 1
    fi
    printf '%s\n' "$latest"
    return 0
  fi

  if [ -f "$input" ]; then
    printf '%s\n' "$input"
    return 0
  fi

  if [ -f "$BACKUP_DIR/$input" ]; then
    printf '%s\n' "$BACKUP_DIR/$input"
    return 0
  fi

  echo "Backup file not found: $input" >&2
  exit 1
}

list_backups() {
  local files=("$BACKUP_DIR"/lumi_backup_*.tar.gz)

  if [ ${#files[@]} -eq 0 ]; then
    echo "No backup files found in:" >&2
    echo "$BACKUP_DIR" >&2
    exit 1
  fi

  echo "Available backups:" >&2
  local i=1
  local f
  for f in "${files[@]}"; do
    printf '  [%d] %s\n' "$i" "$(basename "$f")" >&2
    i=$((i + 1))
  done
}

prompt_for_backup() {
  local files=("$BACKUP_DIR"/lumi_backup_*.tar.gz)
  local choice
  local index

  list_backups
  echo >&2
  read -rp "Type a number, a filename, a full path, or 'latest': " choice

  if [[ "$choice" =~ ^[0-9]+$ ]]; then
    index=$((choice - 1))
    if [ "$index" -ge 0 ] && [ "$index" -lt "${#files[@]}" ]; then
      printf '%s\n' "${files[$index]}"
      return 0
    fi
    echo "Invalid selection: $choice" >&2
    exit 1
  fi

  resolve_backup_file "$choice"
}

if [ $# -eq 0 ]; then
  BACKUP_FILE="$(prompt_for_backup)"
else
  BACKUP_FILE="$(resolve_backup_file "$1")"
fi

if [ ! -f "$BACKUP_FILE" ]; then
  echo "Backup file not found: $BACKUP_FILE" >&2
  exit 1
fi

echo "Using Lumiverse path: $LUMI_DIR"
echo "Using backup path: $BACKUP_DIR"
echo
echo "Backup contents:"
tar -tzf "$BACKUP_FILE"
echo
read -rp "Restore these files into $LUMI_DIR ? [y/N] " CONFIRM

case "$CONFIRM" in
  y|Y|yes|YES) ;;
  *)
    echo "Restore cancelled."
    exit 0
    ;;
esac

echo "Restoring backup..."
tar -xzf "$BACKUP_FILE" -C "$LUMI_DIR"

echo "Done."
echo "Restored from:"
echo "$BACKUP_FILE"
echo "$BACKUP_FILE"
